<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="#18181B"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Verified Assistant Credentials"
        android:textColor="#22C55E"
        android:textSize="20sp"
        android:fontFamily="sans-serif-medium"
        android:textStyle="bold" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:layout_marginBottom="20dp"
        android:text="All credentials have been independently verified by NavAssist Trust &amp; Safety."
        android:textColor="#A1A1AA"
        android:textSize="13sp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="✓ Government Identity Verified (Aadhaar)\n✓ Police Background Verification Passed\n✓ Certified First Aid &amp; Disability Assistance\n✓ Official Station / Airport License Holder"
        android:textColor="#FAFAFA"
        android:textSize="14sp"
        android:lineSpacingExtra="8dp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnCloseCertificates"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:layout_marginTop="24dp"
        android:backgroundTint="#FAFAFA"
        android:text="Close"
        android:textColor="#09090B"
        android:textSize="15sp"
        android:textStyle="bold"
        app:cornerRadius="14dp" />

</LinearLayout>
