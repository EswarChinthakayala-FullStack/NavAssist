<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#09090B">

    <!-- Top Glow Background -->
    <View
        android:layout_width="match_parent"
        android:layout_height="320dp"
        android:alpha="0.35"
        android:background="@drawable/bg_ambient_glow" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- Top Action Bar Header -->
        <LinearLayout
            android:id="@+id/layoutTopHeader"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="56dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp"
            android:paddingVertical="8dp">

            <ImageButton
                android:id="@+id/btnBack"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="@drawable/bg_map_control_button"
                android:contentDescription="Back"
                android:padding="10dp"
                android:scaleType="fitCenter"
                android:src="@drawable/ic_arrow_left"
                app:tint="#FAFAFA" />

            <TextView
                android:id="@+id/tvHeaderTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:fontFamily="sans-serif-medium"
                android:gravity="center"
                android:text="Trip Details"
                android:textColor="#FAFAFA"
                android:textSize="18sp"
                android:textStyle="bold" />

            <ImageButton
                android:id="@+id/btnShareHeader"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="@drawable/bg_map_control_button"
                android:contentDescription="Share Trip"
                android:padding="10dp"
                android:scaleType="fitCenter"
                android:src="@drawable/ic_ms_share"
                app:tint="#FAFAFA" />

        </LinearLayout>

        <!-- Main Scrollable Content -->
        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:clipToPadding="false"
            android:paddingBottom="40dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- 1. Hero Status Card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardHeroStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="#161616"
                app:cardCornerRadius="20dp"
                app:cardElevation="8dp"
                app:strokeColor="#27272A"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <!-- Status Chip + Booking ID Row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:id="@+id/chipStatus"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:background="@drawable/bg_status_chip_completed"
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            android:paddingHorizontal="12dp"
                            android:paddingVertical="6dp">

                            <ImageView
                                android:id="@+id/ivStatusIcon"
                                android:layout_width="16dp"
                                android:layout_height="16dp"
                                android:src="@drawable/ic_ms_check_circle"
                                app:tint="#22C55E" />

                            <TextView
                                android:id="@+id/tvStatusText"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="6dp"
                                android:fontFamily="sans-serif-medium"
                                android:text="COMPLETED"
                                android:textColor="#22C55E"
                                android:textSize="12sp"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <View
                            android:layout_width="0dp"
                            android:layout_height="1dp"
                            android:layout_weight="1" />

                        <TextView
                            android:id="@+id/tvBookingId"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="sans-serif-medium"
                            android:text="Booking #BK-1002"
                            android:textColor="#A1A1AA"
                            android:textSize="13sp" />

                    </LinearLayout>

                    <!-- Date & Main Stats Grid -->
                    <TextView
                        android:id="@+id/tvTripDate"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:fontFamily="sans-serif-medium"
                        android:text="Today • 10:30 AM"
                        android:textColor="#FAFAFA"
                        android:textSize="20sp"
                        android:textStyle="bold" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:background="@drawable/bg_search_bar_glass"
                            android:gravity="center"
                            android:orientation="vertical"
                            android:padding="12dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Est. Duration"
                                android:textColor="#A1A1AA"
                                android:textSize="11sp" />

                            <TextView
                                android:id="@+id/tvTripDuration"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:text="45 min"
                                android:textColor="#FAFAFA"
                                android:textSize="16sp"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <Space
                            android:layout_width="10dp"
                            android:layout_height="1dp" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:background="@drawable/bg_search_bar_glass"
                            android:gravity="center"
                            android:orientation="vertical"
                            android:padding="12dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Distance"
                                android:textColor="#A1A1AA"
                                android:textSize="11sp" />

                            <TextView
                                android:id="@+id/tvTripDistance"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:text="18.6 km"
                                android:textColor="#FAFAFA"
                                android:textSize="16sp"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <Space
                            android:layout_width="10dp"
                            android:layout_height="1dp" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:background="@drawable/bg_search_bar_glass"
                            android:gravity="center"
                            android:orientation="vertical"
                            android:padding="12dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Service"
                                android:textColor="#A1A1AA"
                                android:textSize="11sp" />

                            <TextView
                                android:id="@+id/tvTripType"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:text="Immediate"
                                android:textColor="#3B82F6"
                                android:textSize="14sp"
                                android:textStyle="bold" />
                        </LinearLayout>

                    </LinearLayout>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- 2. Interactive Map Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="220dp"
                android:layout_marginTop="16dp"
                app:cardBackgroundColor="#161616"
                app:cardCornerRadius="20dp"
                app:strokeColor="#27272A"
                app:strokeWidth="1dp">

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">

                    <org.maplibre.android.maps.MapView
                        android:id="@+id/mapView"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent" />

                    <!-- Floating Map Controls Stack -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="end|center_vertical"
                        android:layout_marginEnd="10dp"
                        android:orientation="vertical">

                        <ImageButton
                            android:id="@+id/btnZoomIn"
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:background="@drawable/bg_map_control_button"
                            android:contentDescription="Zoom In"
                            android:padding="8dp"
                            android:scaleType="fitCenter"
                            android:src="@drawable/ic_add"
                            app:tint="#FAFAFA" />

                        <ImageButton
                            android:id="@+id/btnZoomOut"
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:layout_marginTop="6dp"
                            android:background="@drawable/bg_map_control_button"
                            android:contentDescription="Zoom Out"
                            android:padding="8dp"
                            android:scaleType="fitCenter"
                            android:src="@drawable/ic_close"
                            app:tint="#FAFAFA" />

                        <ImageButton
                            android:id="@+id/btnToggleMapStyle"
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:layout_marginTop="6dp"
                            android:background="@drawable/bg_map_control_button"
                            android:contentDescription="Toggle Map Style"
                            android:padding="8dp"
                            android:scaleType="fitCenter"
                            android:src="@drawable/ic_ms_layers"
                            app:tint="#FAFAFA" />

                        <ImageButton
                            android:id="@+id/btnRecenterMap"
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:layout_marginTop="6dp"
                            android:background="@drawable/bg_map_control_button"
                            android:contentDescription="Recenter Map"
                            android:padding="8dp"
                            android:scaleType="fitCenter"
                            android:src="@drawable/ic_ms_my_location"
                            app:tint="#FAFAFA" />

                    </LinearLayout>

                </FrameLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- 3. Assistant (Guide) Profile Card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardAssistantProfile"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:cardBackgroundColor="#161616"
                app:cardCornerRadius="20dp"
                app:strokeColor="#27272A"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Assigned Guide / Assistant"
                        android:textColor="#A1A1AA"
                        android:textSize="12sp"
                        android:textStyle="bold" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <ImageView
                            android:id="@+id/ivAssistantAvatar"
                            android:layout_width="54dp"
                            android:layout_height="54dp"
                            android:background="@drawable/bg_current_location_pill"
                            android:contentDescription="Assistant Photo"
                            android:scaleType="centerCrop"
                            android:src="@drawable/ic_ms_person"
                            app:tint="#FAFAFA" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="14dp"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:gravity="center_vertical"
                                android:orientation="horizontal">

                                <TextView
                                    android:id="@+id/tvAssistantName"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Verified Assistant"
                                    android:textColor="#FAFAFA"
                                    android:textSize="16sp"
                                    android:textStyle="bold" />

                                <ImageView
                                    android:layout_width="16dp"
                                    android:layout_height="16dp"
                                    android:layout_marginStart="6dp"
                                    android:src="@drawable/ic_ms_check_circle"
                                    app:tint="#3B82F6" />

                            </LinearLayout>

                            <TextView
                                android:id="@+id/tvAssistantPhone"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:text="+91 98765 43210"
                                android:textColor="#A1A1AA"
                                android:textSize="13sp" />

                            <TextView
                                android:id="@+id/tvAssistantRating"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:text="★ 4.9 • 120+ Trips"
                                android:textColor="#F59E0B"
                                android:textSize="12sp"
                                android:textStyle="bold" />

                        </LinearLayout>

                    </LinearLayout>

                    <!-- Call & Chat CTAs -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:orientation="horizontal">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnCallAssistant"
                            style="@style/Widget.Material3.Button.OutlinedButton"
                            android:layout_width="0dp"
                            android:layout_height="44dp"
                            android:layout_weight="1"
                            android:text="Call Guide"
                            android:textColor="#FAFAFA"
                            app:cornerRadius="12dp"
                            app:icon="@drawable/ic_phone_outline"
                            app:iconTint="#FAFAFA"
                            app:strokeColor="#3F3F46" />

                        <Space
                            android:layout_width="12dp"
                            android:layout_height="1dp" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnChatAssistant"
                            android:layout_width="0dp"
                            android:layout_height="44dp"
                            android:layout_weight="1"
                            android:backgroundTint="#27272A"
                            android:text="Message"
                            android:textColor="#FAFAFA"
                            app:cornerRadius="12dp"
                            app:icon="@drawable/ic_ms_chat_bubble"
                            app:iconTint="#FAFAFA" />

                    </LinearLayout>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- 4. OTP Verification Card (Visible when status is ARRIVED or ACCEPTED) -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardOtpVerification"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:visibility="gone"
                app:cardBackgroundColor="#1E3A5F"
                app:cardCornerRadius="20dp"
                app:strokeColor="#3B82F6"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="PICKUP OTP CODE"
                        android:textColor="#60A5FA"
                        android:textSize="12sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvOtpCode"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:letterSpacing="0.4"
                        android:text="482910"
                        android:textColor="#FAFAFA"
                        android:textSize="32sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Share this 6-digit OTP with your guide to start the journey"
                        android:textColor="#93C5FD"
                        android:textSize="12sp" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- 5. Pickup & Destination Route Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:cardBackgroundColor="#161616"
                app:cardCornerRadius="20dp"
                app:strokeColor="#27272A"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <!-- Pickup Row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical">

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/ic_ms_location_on"
                            app:tint="#22C55E" />

                        <TextView
                            android:id="@+id/tvPickupAddress"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="12dp"
                            android:text="Talluru Bus Stand, Talluru, Prakasam"
                            android:textColor="#FAFAFA"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                    </LinearLayout>

                    <!-- Connector line -->
                    <View
                        android:layout_width="2dp"
                        android:layout_height="18dp"
                        android:layout_marginStart="9dp"
                        android:layout_marginVertical="4dp"
                        android:background="#3F3F46" />

                    <!-- Destination Row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical">

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/ic_ms_location_on"
                            app:tint="#EF4444" />

                        <TextView
                            android:id="@+id/tvDestinationAddress"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="12dp"
                            android:text="Darsi Center, Darsi, Prakasam"
                            android:textColor="#FAFAFA"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                    </LinearLayout>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- 6. Fare Breakdown Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:cardBackgroundColor="#161616"
                app:cardCornerRadius="20dp"
                app:strokeColor="#27272A"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Fare Breakdown"
                        android:textColor="#A1A1AA"
                        android:textSize="12sp"
                        android:textStyle="bold" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Base Assistance Fare"
                            android:textColor="#D4D4D8"
                            android:textSize="13sp" />

                        <TextView
                            android:id="@+id/tvBaseFare"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="₹120.00"
                            android:textColor="#FAFAFA"
                            android:textSize="13sp" />

                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Platform &amp; Service Fee"
                            android:textColor="#D4D4D8"
                            android:textSize="13sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="₹15.00"
                            android:textColor="#FAFAFA"
                            android:textSize="13sp" />

                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginVertical="12dp"
                        android:background="#27272A" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Total Amount Paid"
                            android:textColor="#FAFAFA"
                            android:textSize="15sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tvTotalFare"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="₹135.00"
                            android:textColor="#22C55E"
                            android:textSize="18sp"
                            android:textStyle="bold" />

                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvPaymentStatus"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Paid via Online / Wallet"
                        android:textColor="#A1A1AA"
                        android:textSize="12sp" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- 7. Receipt & Payment Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:cardBackgroundColor="#161616"
                app:cardCornerRadius="20dp"
                app:strokeColor="#27272A"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="16dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Tax Receipt &amp; Invoice"
                            android:textColor="#FAFAFA"
                            android:textSize="15sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="Official tax invoice available for download"
                            android:textColor="#A1A1AA"
                            android:textSize="12sp" />

                    </LinearLayout>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnViewReceipt"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:layout_width="wrap_content"
                        android:layout_height="44dp"
                        android:text="Receipt"
                        android:textColor="#FAFAFA"
                        app:cornerRadius="12dp"
                        app:strokeColor="#3F3F46" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- 8. Safety Actions Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:orientation="horizontal">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnEmergencySos"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:backgroundTint="#DC2626"
                    android:text="Emergency SOS"
                    android:textColor="#FAFAFA"
                    app:cornerRadius="14dp"
                    app:icon="@drawable/ic_sos"
                    app:iconTint="#FAFAFA" />

                <Space
                    android:layout_width="12dp"
                    android:layout_height="1dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnShareLiveLocation"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:text="Share Trip"
                    android:textColor="#FAFAFA"
                    app:cornerRadius="14dp"
                    app:icon="@drawable/ic_ms_share"
                    app:iconTint="#FAFAFA"
                    app:strokeColor="#3F3F46" />

            </LinearLayout>

            <!-- 9. Dynamic Journey Action CTAs -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnPrimaryAction"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:layout_marginTop="20dp"
                android:backgroundTint="#FAFAFA"
                android:text="Book Again"
                android:textColor="#09090B"
                android:textSize="15sp"
                android:textStyle="bold"
                app:cornerRadius="16dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCancelTrip"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginTop="10dp"
                android:text="Cancel Booking"
                android:textColor="#EF4444"
                android:visibility="gone"
                app:cornerRadius="16dp"
                app:strokeColor="#EF4444" />

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
