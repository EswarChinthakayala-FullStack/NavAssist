<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#09090B"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="32dp">

    <ImageView
        android:layout_width="96dp"
        android:layout_height="96dp"
        android:layout_marginBottom="24dp"
        android:src="@drawable/ic_feature_safety"
        app:tint="#EF4444" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="EMERGENCY ALERT ACTIVE 🔴"
        android:textColor="#EF4444"
        android:textSize="22sp"
        android:fontFamily="sans-serif-medium"
        android:textStyle="bold" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="32dp"
        android:gravity="center"
        android:text="Emergency contacts and NavAssist Safety Command Center have been notified with your live GPS location."
        android:textColor="#A1A1AA"
        android:textSize="14sp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnCancelSos"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:backgroundTint="#27272A"
        android:text="Cancel SOS Alert"
        android:textColor="#FAFAFA"
        android:textSize="15sp"
        app:cornerRadius="14dp" />

</LinearLayout>
