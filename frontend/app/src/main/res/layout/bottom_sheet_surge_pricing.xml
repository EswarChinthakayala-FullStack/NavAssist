<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="#18181B"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Surge Fare Notice (1.2x)"
        android:textColor="#F59E0B"
        android:textSize="20sp"
        android:fontFamily="sans-serif-medium"
        android:textStyle="bold" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:layout_marginBottom="16dp"
        android:text="Fares are higher than usual due to peak passenger traffic at this terminal."
        android:textColor="#A1A1AA"
        android:textSize="13sp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Base Fare: ₹250.00\nDemand Multiplier: 1.2x (+₹50.00)\nEstimated Total: ₹300.00"
        android:textColor="#FAFAFA"
        android:textSize="14sp"
        android:lineSpacingExtra="6dp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnAcceptSurge"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:layout_marginTop="24dp"
        android:backgroundTint="#F59E0B"
        android:text="Accept &amp; Continue"
        android:textColor="#09090B"
        android:textSize="15sp"
        android:textStyle="bold"
        app:cornerRadius="14dp" />

</LinearLayout>
