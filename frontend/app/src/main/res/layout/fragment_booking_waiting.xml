<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#09090B"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="32dp">

    <com.google.android.material.progressindicator.CircularProgressIndicator
        android:layout_width="72dp"
        android:layout_height="72dp"
        android:layout_marginBottom="24dp"
        android:indeterminate="true"
        app:indicatorColor="#22C55E"
        app:trackColor="#27272A" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Finding Nearby Guide..."
        android:textColor="#FAFAFA"
        android:textSize="22sp"
        android:fontFamily="sans-serif-medium"
        android:textStyle="bold" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="48dp"
        android:gravity="center"
        android:text="Matching your booking with verified local assistants within 500m radius."
        android:textColor="#A1A1AA"
        android:textSize="14sp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnCancelSearch"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:backgroundTint="#27272A"
        android:text="Cancel Request"
        android:textColor="#FAFAFA"
        android:textSize="15sp"
        app:cornerRadius="14dp" />

</LinearLayout>
