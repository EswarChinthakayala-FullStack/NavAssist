<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/registerContainer"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#09090B"
    android:fitsSystemWindows="true">

    <!-- Reusable 8-Layer Navigation Grid & Ambient Lighting Background -->
    <com.navassist.android.presentation.widgets.background.NavigationGridBackgroundView
        android:id="@+id/vNavigationBackground"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Scrollable Registration Container -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:overScrollMode="never">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingBottom="24dp">

            <!-- Logo Section: Official App Logo inside 64dp Circular Surface -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardLogo"
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:layout_marginTop="28dp"
                app:cardBackgroundColor="#18181B"
                app:cardCornerRadius="32dp"
                app:cardElevation="4dp"
                app:strokeColor="#303038"
                app:strokeWidth="1dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent">

                <ImageView
                    android:id="@+id/ivBrandLogo"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:layout_gravity="center"
                    android:contentDescription="@string/app_name"
                    android:src="@drawable/ic_app_logo" />

            </com.google.android.material.card.MaterialCardView>

            <!-- Typography Header Section -->
            <TextView
                android:id="@+id/tvHeadline"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:letterSpacing="-0.01"
                android:text="@string/create_your_account"
                android:textColor="#FAFAFA"
                android:textSize="28sp"
                android:textStyle="bold"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/cardLogo" />

            <TextView
                android:id="@+id/tvSubtitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="36dp"
                android:layout_marginTop="6dp"
                android:layout_marginEnd="36dp"
                android:gravity="center"
                android:text="@string/signup_subtitle"
                android:textColor="#A1A1AA"
                android:textSize="14sp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tvHeadline" />

            <!-- 28dp Glass-Inspired Floating Registration Card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardRegister"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:layout_marginTop="20dp"
                android:layout_marginEnd="20dp"
                app:cardBackgroundColor="#18181B"
                app:cardCornerRadius="28dp"
                app:cardElevation="12dp"
                app:strokeColor="#303038"
                app:strokeWidth="1dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tvSubtitle">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="24dp">

                    <!-- Role Selection Header & Cards -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Select Account Type"
                        android:textColor="#FAFAFA"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                    <LinearLayout
                        android:id="@+id/layoutRoleSelector"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:orientation="horizontal">

                        <!-- Role 1: Passenger / Traveler Card -->
                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/cardRolePassenger"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="6dp"
                            android:layout_weight="1"
                            android:clickable="true"
                            android:focusable="true"
                            app:cardBackgroundColor="#242428"
                            app:cardCornerRadius="16dp"
                            app:strokeColor="#FFFFFF"
                            app:strokeWidth="1.5dp">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:gravity="center"
                                android:orientation="vertical"
                                android:padding="14dp">

                                <ImageView
                                    android:id="@+id/ivPassengerIcon"
                                    android:layout_width="24dp"
                                    android:layout_height="24dp"
                                    android:contentDescription="Passenger"
                                    android:src="@drawable/ic_role_passenger"
                                    app:tint="#FAFAFA" />

                                <TextView
                                    android:id="@+id/tvPassengerTitle"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="6dp"
                                    android:text="Passenger"
                                    android:textColor="#FAFAFA"
                                    android:textSize="13sp"
                                    android:textStyle="bold" />

                                <TextView
                                    android:id="@+id/tvPassengerSubtitle"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="2dp"
                                    android:gravity="center"
                                    android:text="Book assistance"
                                    android:textColor="#A1A1AA"
                                    android:textSize="11sp" />

                            </LinearLayout>

                        </com.google.android.material.card.MaterialCardView>

                        <!-- Role 2: Assistant Guide Card -->
                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/cardRoleAssistant"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="6dp"
                            android:layout_weight="1"
                            android:clickable="true"
                            android:focusable="true"
                            app:cardBackgroundColor="#18181B"
                            app:cardCornerRadius="16dp"
                            app:strokeColor="#2F2F35"
                            app:strokeWidth="1dp">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:gravity="center"
                                android:orientation="vertical"
                                android:padding="14dp">

                                <ImageView
                                    android:id="@+id/ivAssistantIcon"
                                    android:layout_width="24dp"
                                    android:layout_height="24dp"
                                    android:contentDescription="Assistant"
                                    android:src="@drawable/ic_role_assistant"
                                    app:tint="#71717A" />

                                <TextView
                                    android:id="@+id/tvAssistantTitle"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="6dp"
                                    android:text="Travel Assistant"
                                    android:textColor="#A1A1AA"
                                    android:textSize="13sp"
                                    android:textStyle="bold" />

                                <TextView
                                    android:id="@+id/tvAssistantSubtitle"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="2dp"
                                    android:gravity="center"
                                    android:text="Provide assistance"
                                    android:textColor="#71717A"
                                    android:textSize="11sp" />

                            </LinearLayout>

                        </com.google.android.material.card.MaterialCardView>

                    </LinearLayout>

                    <!-- Field 1: Full Name -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:text="@string/label_full_name"
                        android:textColor="#FAFAFA"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                    <RelativeLayout
                        android:id="@+id/layoutNameContainer"
                        android:layout_width="match_parent"
                        android:layout_height="54dp"
                        android:layout_marginTop="6dp"
                        android:background="@drawable/bg_input_field"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp">

                        <FrameLayout
                            android:id="@+id/flNameIcon"
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:layout_centerVertical="true"
                            android:background="@drawable/bg_icon_circle">

                            <ImageView
                                android:layout_width="18dp"
                                android:layout_height="18dp"
                                android:layout_gravity="center"
                                android:contentDescription="@string/label_full_name"
                                android:src="@drawable/ic_person_outline" />

                        </FrameLayout>

                        <EditText
                            android:id="@+id/etFullName"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:layout_marginStart="10dp"
                            android:layout_toEndOf="@id/flNameIcon"
                            android:background="@null"
                            android:hint="John Doe"
                            android:inputType="textPersonName"
                            android:textColor="#FAFAFA"
                            android:textColorHint="#71717A"
                            android:textSize="15sp" />

                    </RelativeLayout>

                    <!-- Field 2: Phone Number -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:text="@string/phone_number"
                        android:textColor="#FAFAFA"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                    <RelativeLayout
                        android:id="@+id/layoutPhoneContainer"
                        android:layout_width="match_parent"
                        android:layout_height="54dp"
                        android:layout_marginTop="6dp"
                        android:background="@drawable/bg_input_field"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp">

                        <FrameLayout
                            android:id="@+id/flPhoneIcon"
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:layout_centerVertical="true"
                            android:background="@drawable/bg_icon_circle">

                            <ImageView
                                android:layout_width="18dp"
                                android:layout_height="18dp"
                                android:layout_gravity="center"
                                android:contentDescription="@string/phone_number"
                                android:src="@drawable/ic_phone_outline" />

                        </FrameLayout>

                        <TextView
                            android:id="@+id/tvCountryCode"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_centerVertical="true"
                            android:layout_marginStart="10dp"
                            android:layout_toEndOf="@id/flPhoneIcon"
                            android:text="+91 "
                            android:textColor="#A1A1AA"
                            android:textSize="15sp"
                            android:textStyle="bold" />

                        <EditText
                            android:id="@+id/etPhone"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:layout_marginStart="4dp"
                            android:layout_toEndOf="@id/tvCountryCode"
                            android:background="@null"
                            android:hint="98765 43210"
                            android:inputType="phone"
                            android:maxLength="10"
                            android:textColor="#FAFAFA"
                            android:textColorHint="#71717A"
                            android:textSize="15sp" />

                    </RelativeLayout>

                    <!-- Field 3: Email Address -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:text="@string/label_email_address"
                        android:textColor="#FAFAFA"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                    <RelativeLayout
                        android:id="@+id/layoutEmailContainer"
                        android:layout_width="match_parent"
                        android:layout_height="54dp"
                        android:layout_marginTop="6dp"
                        android:background="@drawable/bg_input_field"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp">

                        <FrameLayout
                            android:id="@+id/flEmailIcon"
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:layout_centerVertical="true"
                            android:background="@drawable/bg_icon_circle">

                            <ImageView
                                android:layout_width="18dp"
                                android:layout_height="18dp"
                                android:layout_gravity="center"
                                android:contentDescription="@string/label_email_address"
                                android:src="@drawable/ic_email_outline" />

                        </FrameLayout>

                        <EditText
                            android:id="@+id/etEmail"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:layout_marginStart="10dp"
                            android:layout_toEndOf="@id/flEmailIcon"
                            android:background="@null"
                            android:hint="john.doe@example.com"
                            android:inputType="textEmailAddress"
                            android:textColor="#FAFAFA"
                            android:textColorHint="#71717A"
                            android:textSize="15sp" />

                    </RelativeLayout>

                    <!-- Field 4: Password -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:text="@string/password"
                        android:textColor="#FAFAFA"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                    <RelativeLayout
                        android:id="@+id/layoutPasswordContainer"
                        android:layout_width="match_parent"
                        android:layout_height="54dp"
                        android:layout_marginTop="6dp"
                        android:background="@drawable/bg_input_field"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp">

                        <FrameLayout
                            android:id="@+id/flLockIcon"
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:layout_centerVertical="true"
                            android:background="@drawable/bg_icon_circle">

                            <ImageView
                                android:layout_width="18dp"
                                android:layout_height="18dp"
                                android:layout_gravity="center"
                                android:contentDescription="@string/password"
                                android:src="@drawable/ic_lock_outline" />

                        </FrameLayout>

                        <EditText
                            android:id="@+id/etPassword"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:layout_marginStart="10dp"
                            android:layout_toStartOf="@id/flEyeToggle"
                            android:layout_toEndOf="@id/flLockIcon"
                            android:background="@null"
                            android:hint="Create password"
                            android:inputType="textPassword"
                            android:textColor="#FAFAFA"
                            android:textColorHint="#71717A"
                            android:textSize="15sp" />

                        <FrameLayout
                            android:id="@+id/flEyeToggle"
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:layout_alignParentEnd="true"
                            android:layout_centerVertical="true"
                            android:clickable="true"
                            android:focusable="true">

                            <ImageView
                                android:id="@+id/ivEyeToggle"
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:layout_gravity="center"
                                android:contentDescription="@string/password"
                                android:src="@drawable/ic_eye_off" />

                        </FrameLayout>

                    </RelativeLayout>

                    <!-- Field 5: Confirm Password -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:text="@string/label_confirm_password"
                        android:textColor="#FAFAFA"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                    <RelativeLayout
                        android:id="@+id/layoutConfirmPasswordContainer"
                        android:layout_width="match_parent"
                        android:layout_height="54dp"
                        android:layout_marginTop="6dp"
                        android:background="@drawable/bg_input_field"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp">

                        <FrameLayout
                            android:id="@+id/flConfirmLockIcon"
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:layout_centerVertical="true"
                            android:background="@drawable/bg_icon_circle">

                            <ImageView
                                android:layout_width="18dp"
                                android:layout_height="18dp"
                                android:layout_gravity="center"
                                android:contentDescription="@string/label_confirm_password"
                                android:src="@drawable/ic_lock_outline" />

                        </FrameLayout>

                        <EditText
                            android:id="@+id/etConfirmPassword"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:layout_marginStart="10dp"
                            android:layout_toStartOf="@id/tvConfirmMatch"
                            android:layout_toEndOf="@id/flConfirmLockIcon"
                            android:background="@null"
                            android:hint="Re-enter password"
                            android:inputType="textPassword"
                            android:textColor="#FAFAFA"
                            android:textColorHint="#71717A"
                            android:textSize="15sp" />

                        <TextView
                            android:id="@+id/tvConfirmMatch"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:layout_centerVertical="true"
                            android:text="✓ Match"
                            android:textColor="#22C55E"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:visibility="gone"
                            tools:visibility="visible" />

                    </RelativeLayout>

                    <!-- Live Password Requirements Checklist -->
                    <LinearLayout
                        android:id="@+id/layoutPasswordRequirements"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:orientation="vertical"
                        android:paddingStart="4dp"
                        android:paddingEnd="4dp">

                        <TextView
                            android:id="@+id/tvReqLength"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="• Minimum 8 characters"
                            android:textColor="#71717A"
                            android:textSize="12sp" />

                        <TextView
                            android:id="@+id/tvReqUppercase"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="• At least 1 uppercase letter"
                            android:textColor="#71717A"
                            android:textSize="12sp" />

                        <TextView
                            android:id="@+id/tvReqLowercase"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="• At least 1 lowercase letter"
                            android:textColor="#71717A"
                            android:textSize="12sp" />

                        <TextView
                            android:id="@+id/tvReqNumber"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="• At least 1 number"
                            android:textColor="#71717A"
                            android:textSize="12sp" />

                        <TextView
                            android:id="@+id/tvReqSpecial"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="• At least 1 special character"
                            android:textColor="#71717A"
                            android:textSize="12sp" />

                    </LinearLayout>

                    <!-- Terms & Privacy Checkbox -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <com.google.android.material.checkbox.MaterialCheckBox
                            android:id="@+id/cbTerms"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            app:buttonTint="#FAFAFA" />

                        <TextView
                            android:id="@+id/tvTermsText"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/terms_and_privacy_agree"
                            android:textColor="#A1A1AA"
                            android:textSize="12sp" />

                    </LinearLayout>

                    <!-- Animated Error Chip Container -->
                    <LinearLayout
                        android:id="@+id/layoutErrorChip"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:background="@drawable/bg_error_chip"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingStart="14dp"
                        android:paddingTop="10dp"
                        android:paddingEnd="14dp"
                        android:paddingBottom="10dp"
                        android:visibility="gone"
                        tools:visibility="visible">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="❌ "
                            android:textSize="14sp" />

                        <TextView
                            android:id="@+id/tvErrorInline"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textColor="#EF4444"
                            android:textSize="13sp"
                            tools:text="Please complete all required fields." />

                    </LinearLayout>

                    <!-- Flagship 60dp Pure White CTA Button -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/cardRegisterCta"
                        android:layout_width="match_parent"
                        android:layout_height="60dp"
                        android:layout_marginTop="20dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:contentDescription="@string/btn_create_account"
                        app:cardBackgroundColor="#FFFFFF"
                        app:cardCornerRadius="20dp"
                        app:cardElevation="6dp">

                        <androidx.constraintlayout.widget.ConstraintLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:paddingStart="24dp"
                            android:paddingEnd="12dp">

                            <TextView
                                android:id="@+id/tvRegisterCta"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:letterSpacing="0.02"
                                android:text="@string/btn_create_account"
                                android:textColor="#09090B"
                                android:textSize="16sp"
                                android:textStyle="bold"
                                app:layout_constraintBottom_toBottomOf="parent"
                                app:layout_constraintStart_toStartOf="parent"
                                app:layout_constraintTop_toTopOf="parent" />

                            <ProgressBar
                                android:id="@+id/pbLoading"
                                android:layout_width="26dp"
                                android:layout_height="26dp"
                                android:indeterminateTint="#09090B"
                                android:visibility="gone"
                                app:layout_constraintBottom_toBottomOf="parent"
                                app:layout_constraintEnd_toEndOf="parent"
                                app:layout_constraintStart_toStartOf="parent"
                                app:layout_constraintTop_toTopOf="parent" />

                            <!-- Trailing Arrow inside Circular Black Container -->
                            <FrameLayout
                                android:id="@+id/vArrowCircle"
                                android:layout_width="40dp"
                                android:layout_height="40dp"
                                android:background="@drawable/bg_icon_circle"
                                app:layout_constraintBottom_toBottomOf="parent"
                                app:layout_constraintEnd_toEndOf="parent"
                                app:layout_constraintTop_toTopOf="parent">

                                <ImageView
                                    android:id="@+id/ivArrow"
                                    android:layout_width="20dp"
                                    android:layout_height="20dp"
                                    android:layout_gravity="center"
                                    android:contentDescription="@string/btn_create_account"
                                    android:src="@drawable/ic_arrow_right"
                                    app:tint="#FFFFFF" />

                            </FrameLayout>

                        </androidx.constraintlayout.widget.ConstraintLayout>

                    </com.google.android.material.card.MaterialCardView>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Footer Section: Divider & Sign In Link -->
            <TextView
                android:id="@+id/tvDivider"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="28dp"
                android:letterSpacing="0.05"
                android:text="────────  OR  ────────"
                android:textColor="#303038"
                android:textSize="13sp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/cardRegister" />

            <TextView
                android:id="@+id/tvLogin"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:clickable="true"
                android:focusable="true"
                android:padding="8dp"
                android:text="@string/has_account"
                android:textColor="#A1A1AA"
                android:textSize="14sp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tvDivider" />

        </androidx.constraintlayout.widget.ConstraintLayout>

    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
