<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/coordinatorLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#09090B">

    <!-- Ambient Glow Top Backdrop -->
    <View
        android:id="@+id/vAmbientGlow"
        android:layout_width="match_parent"
        android:layout_height="320dp"
        android:background="@drawable/bg_ambient_glow"
        android:alpha="0.4" />

    <!-- App Bar Toolbar -->
    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appBarLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@android:color/transparent"
        app:elevation="0dp">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:title="Admin Console"
            app:titleTextColor="#FAFAFA"
            app:navigationIcon="@drawable/ic_arrow_left"
            app:navigationIconTint="#FAFAFA" />

    </com.google.android.material.appbar.AppBarLayout>

    <!-- Scrollable Main Content -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/nestedScrollView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingBottom="88dp"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingTop="8dp">

            <TextView
                android:id="@+id/tvSubtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:text="NavAssist Operations &amp; Enterprise Management System"
                android:textColor="#A1A1AA"
                android:textSize="14sp" />

            <!-- Skeleton Loading Shimmer -->
            <com.navassist.android.presentation.admin.widgets.AdminSkeletonView
                android:id="@+id/skeletonView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:visibility="gone" />

            <!-- Main Content Layout -->
            <LinearLayout
                android:id="@+id/layoutContent"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- Section Header: Operational Metrics -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="REAL-TIME METRICS &amp; KPIS"
                    android:textColor="#FAFAFA"
                    android:textSize="13sp"
                    android:fontFamily="sans-serif-medium"
                    android:textStyle="bold"
                    android:letterSpacing="0.05"
                    android:layout_marginBottom="12dp" />

                <!-- Row 1: Users & Bookings -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="12dp">

                    <com.navassist.android.presentation.admin.widgets.AdminStatCard
                        android:id="@+id/statRegisteredUsers"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="6dp" />

                    <com.navassist.android.presentation.admin.widgets.AdminStatCard
                        android:id="@+id/statTotalBookings"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="6dp" />

                </LinearLayout>

                <!-- Row 2: Pending KYC & Open Tickets -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="12dp">

                    <com.navassist.android.presentation.admin.widgets.AdminStatCard
                        android:id="@+id/statPendingKyc"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="6dp" />

                    <com.navassist.android.presentation.admin.widgets.AdminStatCard
                        android:id="@+id/statOpenTickets"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="6dp" />

                </LinearLayout>

                <!-- Row 3: Platform Revenue Hero Card -->
                <com.navassist.android.presentation.admin.widgets.AdminStatCard
                    android:id="@+id/statPlatformRevenue"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="24dp" />

                <!-- Section Header: Management Console -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="OPERATIONS MANAGEMENT CONSOLE"
                    android:textColor="#FAFAFA"
                    android:textSize="13sp"
                    android:fontFamily="sans-serif-medium"
                    android:textStyle="bold"
                    android:letterSpacing="0.05"
                    android:layout_marginBottom="12dp" />

                <com.navassist.android.presentation.admin.widgets.AdminActionCard
                    android:id="@+id/actionKycQueue"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="10dp" />

                <com.navassist.android.presentation.admin.widgets.AdminActionCard
                    android:id="@+id/actionUserManagement"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="10dp" />

                <com.navassist.android.presentation.admin.widgets.AdminActionCard
                    android:id="@+id/actionBookingsManagement"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="10dp" />

                <com.navassist.android.presentation.admin.widgets.AdminActionCard
                    android:id="@+id/actionSosMonitor"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="10dp" />

            </LinearLayout>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

    <!-- Floating Refresh FAB -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabRefreshAdmin"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_margin="20dp"
        android:contentDescription="Refresh Admin Console"
        app:backgroundTint="#FAFAFA"
        app:tint="#09090B"
        app:srcCompat="@drawable/ic_add" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
