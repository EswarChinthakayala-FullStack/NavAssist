<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/loginContainer"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#09090B"
    android:fitsSystemWindows="true">

    <!-- Reusable 8-Layer Navigation Grid & Ambient Lighting Background -->
    <com.navassist.android.presentation.widgets.background.NavigationGridBackgroundView
        android:id="@+id/vNavigationBackground"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Scrollable Content View -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:overScrollMode="never">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingBottom="24dp">

            <!-- Logo Section: Official App Logo inside 64dp Circular Surface -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardLogo"
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:layout_marginTop="32dp"
                app:cardBackgroundColor="#18181B"
                app:cardCornerRadius="32dp"
                app:cardElevation="4dp"
                app:strokeColor="#303038"
                app:strokeWidth="1dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent">

                <ImageView
                    android:id="@+id/ivBrandLogo"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:layout_gravity="center"
                    android:contentDescription="@string/app_name"
                    android:src="@drawable/ic_app_logo" />

            </com.google.android.material.card.MaterialCardView>

            <!-- Typography Header Section -->
            <TextView
                android:id="@+id/tvHeadline"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:letterSpacing="-0.01"
                android:text="@string/welcome_back"
                android:textColor="#FAFAFA"
                android:textSize="30sp"
                android:textStyle="bold"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/cardLogo" />

            <TextView
                android:id="@+id/tvSubtitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="36dp"
                android:layout_marginTop="6dp"
                android:layout_marginEnd="36dp"
                android:gravity="center"
                android:text="Continue your journey safely with NavAssist"
                android:textColor="#A1A1AA"
                android:textSize="15sp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tvHeadline" />

            <!-- 58dp Height Capsule Method Switcher -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardSelector"
                android:layout_width="0dp"
                android:layout_height="58dp"
                android:layout_marginStart="24dp"
                android:layout_marginTop="24dp"
                android:layout_marginEnd="24dp"
                app:cardBackgroundColor="#18181B"
                app:cardCornerRadius="29dp"
                app:strokeColor="#2F2F35"
                app:strokeWidth="1dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tvSubtitle">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:padding="4dp">

                    <!-- Active Sliding White Capsule -->
                    <View
                        android:id="@+id/vSegmentPill"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:background="@drawable/bg_button_primary"
                        app:layout_constraintEnd_toStartOf="@id/tvTabOtp"
                        app:layout_constraintStart_toStartOf="parent" />

                    <TextView
                        android:id="@+id/tvTabPassword"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center"
                        android:text="Phone + Password"
                        android:textColor="#09090B"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toStartOf="@id/tvTabOtp"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <TextView
                        android:id="@+id/tvTabOtp"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center"
                        android:text="Phone + OTP"
                        android:textColor="#A1A1AA"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toEndOf="@id/tvTabPassword"
                        app:layout_constraintTop_toTopOf="parent" />

                </androidx.constraintlayout.widget.ConstraintLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- 28dp Glass-Inspired Floating Login Card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardLogin"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:layout_marginTop="20dp"
                android:layout_marginEnd="20dp"
                app:cardBackgroundColor="#18181B"
                app:cardCornerRadius="28dp"
                app:cardElevation="12dp"
                app:strokeColor="#2F2F35"
                app:strokeWidth="1dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/cardSelector">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="28dp">

                    <!-- Phone Input Field Section -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/phone_number"
                        android:textColor="#FAFAFA"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                    <RelativeLayout
                        android:id="@+id/layoutPhoneContainer"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:layout_marginTop="8dp"
                        android:background="@drawable/bg_input_field"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp">

                        <!-- Circular Phone Icon Container -->
                        <FrameLayout
                            android:id="@+id/flPhoneIcon"
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:layout_centerVertical="true"
                            android:background="@drawable/bg_icon_circle">

                            <ImageView
                                android:layout_width="18dp"
                                android:layout_height="18dp"
                                android:layout_gravity="center"
                                android:contentDescription="@string/phone_number"
                                android:src="@drawable/ic_phone_outline" />

                        </FrameLayout>

                        <!-- Country Code Pill -->
                        <TextView
                            android:id="@+id/tvCountryCode"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_centerVertical="true"
                            android:layout_marginStart="10dp"
                            android:layout_toEndOf="@id/flPhoneIcon"
                            android:text="+91 "
                            android:textColor="#A1A1AA"
                            android:textSize="15sp"
                            android:textStyle="bold" />

                        <EditText
                            android:id="@+id/etPhone"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:layout_marginStart="4dp"
                            android:layout_toEndOf="@id/tvCountryCode"
                            android:background="@null"
                            android:hint="98765 43210"
                            android:inputType="phone"
                            android:maxLength="10"
                            android:textColor="#FAFAFA"
                            android:textColorHint="#71717A"
                            android:textSize="15sp" />

                    </RelativeLayout>

                    <!-- Password Mode Section -->
                    <LinearLayout
                        android:id="@+id/layoutPasswordSection"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="18dp"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/password"
                            android:textColor="#FAFAFA"
                            android:textSize="13sp"
                            android:textStyle="bold" />

                        <RelativeLayout
                            android:id="@+id/layoutPasswordContainer"
                            android:layout_width="match_parent"
                            android:layout_height="56dp"
                            android:layout_marginTop="8dp"
                            android:background="@drawable/bg_input_field"
                            android:paddingStart="12dp"
                            android:paddingEnd="12dp">

                            <!-- Circular Lock Icon Container -->
                            <FrameLayout
                                android:id="@+id/flLockIcon"
                                android:layout_width="36dp"
                                android:layout_height="36dp"
                                android:layout_centerVertical="true"
                                android:background="@drawable/bg_icon_circle">

                                <ImageView
                                    android:layout_width="18dp"
                                    android:layout_height="18dp"
                                    android:layout_gravity="center"
                                    android:contentDescription="@string/password"
                                    android:src="@drawable/ic_lock_outline" />

                            </FrameLayout>

                            <EditText
                                android:id="@+id/etPassword"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:layout_marginStart="10dp"
                                android:layout_toStartOf="@id/flEyeToggle"
                                android:layout_toEndOf="@id/flLockIcon"
                                android:background="@null"
                                android:hint="Enter password"
                                android:inputType="textPassword"
                                android:textColor="#FAFAFA"
                                android:textColorHint="#71717A"
                                android:textSize="15sp" />

                            <!-- Eye Toggle Circular Container -->
                            <FrameLayout
                                android:id="@+id/flEyeToggle"
                                android:layout_width="36dp"
                                android:layout_height="36dp"
                                android:layout_alignParentEnd="true"
                                android:layout_centerVertical="true"
                                android:clickable="true"
                                android:focusable="true">

                                <ImageView
                                    android:id="@+id/ivEyeToggle"
                                    android:layout_width="20dp"
                                    android:layout_height="20dp"
                                    android:layout_gravity="center"
                                    android:contentDescription="@string/password"
                                    android:src="@drawable/ic_eye_off" />

                            </FrameLayout>

                        </RelativeLayout>

                        <TextView
                            android:id="@+id/tvForgotPassword"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="end"
                            android:layout_marginTop="10dp"
                            android:clickable="true"
                            android:focusable="true"
                            android:text="@string/auth_forgot_password"
                            android:textColor="#A1A1AA"
                            android:textSize="13sp" />

                    </LinearLayout>

                    <!-- OTP Mode Section -->
                    <LinearLayout
                        android:id="@+id/layoutOtpSection"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="18dp"
                        android:orientation="vertical"
                        android:visibility="gone"
                        tools:visibility="visible">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnRequestOtp"
                            style="@style/Widget.Material3.Button.OutlinedButton"
                            android:layout_width="match_parent"
                            android:layout_height="52dp"
                            android:text="Request OTP"
                            android:textColor="#FAFAFA"
                            app:cornerRadius="16dp"
                            app:strokeColor="#2F2F35" />

                        <LinearLayout
                            android:id="@+id/layoutOtpInputContainer"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="18dp"
                            android:gravity="center"
                            android:orientation="vertical"
                            android:visibility="gone"
                            tools:visibility="visible">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Enter 6-Digit OTP"
                                android:textColor="#FAFAFA"
                                android:textSize="13sp"
                                android:textStyle="bold" />

                            <com.navassist.android.presentation.widgets.input.OtpInputView
                                android:id="@+id/otpInputView"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="12dp" />

                            <TextView
                                android:id="@+id/tvOtpTimer"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="12dp"
                                android:text="Resend OTP in 60s"
                                android:textColor="#F59E0B"
                                android:textSize="13sp" />

                            <TextView
                                android:id="@+id/btnResendOtp"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="8dp"
                                android:clickable="true"
                                android:focusable="true"
                                android:padding="6dp"
                                android:text="Resend OTP"
                                android:textColor="#FAFAFA"
                                android:textSize="13sp"
                                android:textStyle="bold"
                                android:visibility="gone" />

                        </LinearLayout>

                    </LinearLayout>

                    <!-- Animated Error Chip Container -->
                    <LinearLayout
                        android:id="@+id/layoutErrorChip"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:background="@drawable/bg_error_chip"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingStart="14dp"
                        android:paddingTop="10dp"
                        android:paddingEnd="14dp"
                        android:paddingBottom="10dp"
                        android:visibility="gone"
                        tools:visibility="visible">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="❌ "
                            android:textSize="14sp" />

                        <TextView
                            android:id="@+id/tvErrorInline"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textColor="#EF4444"
                            android:textSize="13sp"
                            tools:text="Invalid phone number or password." />

                    </LinearLayout>

                    <!-- Flagship 60dp Pure White CTA Button -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/cardLoginCta"
                        android:layout_width="match_parent"
                        android:layout_height="60dp"
                        android:layout_marginTop="24dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:contentDescription="@string/login"
                        app:cardBackgroundColor="#FFFFFF"
                        app:cardCornerRadius="20dp"
                        app:cardElevation="6dp">

                        <androidx.constraintlayout.widget.ConstraintLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:paddingStart="24dp"
                            android:paddingEnd="12dp">

                            <TextView
                                android:id="@+id/tvLoginCta"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:letterSpacing="0.02"
                                android:text="@string/login"
                                android:textColor="#09090B"
                                android:textSize="16sp"
                                android:textStyle="bold"
                                app:layout_constraintBottom_toBottomOf="parent"
                                app:layout_constraintStart_toStartOf="parent"
                                app:layout_constraintTop_toTopOf="parent" />

                            <ProgressBar
                                android:id="@+id/pbLoading"
                                android:layout_width="26dp"
                                android:layout_height="26dp"
                                android:indeterminateTint="#09090B"
                                android:visibility="gone"
                                app:layout_constraintBottom_toBottomOf="parent"
                                app:layout_constraintEnd_toEndOf="parent"
                                app:layout_constraintStart_toStartOf="parent"
                                app:layout_constraintTop_toTopOf="parent" />

                            <!-- Trailing Arrow inside Circular Black Container -->
                            <FrameLayout
                                android:id="@+id/vArrowCircle"
                                android:layout_width="40dp"
                                android:layout_height="40dp"
                                android:background="@drawable/bg_icon_circle"
                                app:layout_constraintBottom_toBottomOf="parent"
                                app:layout_constraintEnd_toEndOf="parent"
                                app:layout_constraintTop_toTopOf="parent">

                                <ImageView
                                    android:id="@+id/ivArrow"
                                    android:layout_width="20dp"
                                    android:layout_height="20dp"
                                    android:layout_gravity="center"
                                    android:contentDescription="@string/login"
                                    android:src="@drawable/ic_arrow_right"
                                    app:tint="#FFFFFF" />

                            </FrameLayout>

                        </androidx.constraintlayout.widget.ConstraintLayout>

                    </com.google.android.material.card.MaterialCardView>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Footer Section: Divider & Sign Up Action -->
            <TextView
                android:id="@+id/tvDivider"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="28dp"
                android:letterSpacing="0.05"
                android:text="────────  OR  ────────"
                android:textColor="#303038"
                android:textSize="13sp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/cardLogin" />

            <TextView
                android:id="@+id/tvRegister"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:clickable="true"
                android:focusable="true"
                android:padding="8dp"
                android:text="@string/no_account"
                android:textColor="#A1A1AA"
                android:textSize="14sp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tvDivider" />

        </androidx.constraintlayout.widget.ConstraintLayout>

    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
