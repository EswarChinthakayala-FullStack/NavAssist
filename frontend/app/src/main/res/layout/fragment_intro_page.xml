<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/introPageContainer"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    tools:background="#09090B">

    <!-- Ambient Glow Background Surface Overlay -->
    <View
        android:id="@+id/vPageAmbientGlow"
        android:layout_width="320dp"
        android:layout_height="320dp"
        android:alpha="0.4"
        android:background="@drawable/bg_ambient_glow"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Top Guideline for Hero Container (45% screen height) -->
    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guidelineHero"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintGuide_percent="0.45" />

    <!-- Hero Card Surface -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardHero"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginStart="32dp"
        android:layout_marginTop="56dp"
        android:layout_marginEnd="32dp"
        app:cardBackgroundColor="#18181B"
        app:cardCornerRadius="24dp"
        app:cardElevation="6dp"
        app:strokeColor="#3F3F46"
        app:strokeWidth="1dp"
        app:layout_constraintBottom_toTopOf="@id/guidelineHero"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/ivHero"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_gravity="center"
            android:padding="24dp"
            android:contentDescription="@string/app_name"
            tools:src="@drawable/ic_onboarding_hero_1_welcome" />

    </com.google.android.material.card.MaterialCardView>

    <!-- Page Title Headline -->
    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="32dp"
        android:layout_marginTop="36dp"
        android:layout_marginEnd="32dp"
        android:gravity="center"
        android:letterSpacing="-0.01"
        android:textColor="#FAFAFA"
        android:textSize="26sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/guidelineHero"
        tools:text="Travel Smarter.\nNavigate with Confidence." />

    <!-- Supporting Description Text -->
    <TextView
        android:id="@+id/tvDescription"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="36dp"
        android:layout_marginTop="12dp"
        android:layout_marginEnd="36dp"
        android:gravity="center"
        android:lineSpacingExtra="4dp"
        android:maxLines="3"
        android:textColor="#A1A1AA"
        android:textSize="15sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvTitle"
        tools:text="Experience the next generation of personal navigation and on-demand assistant services." />

</androidx.constraintlayout.widget.ConstraintLayout>
