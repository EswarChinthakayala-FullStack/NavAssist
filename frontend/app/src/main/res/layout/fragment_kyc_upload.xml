<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/coordinatorLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#09090B">

    <!-- Ambient Glow Backdrop -->
    <View
        android:id="@+id/vAmbientGlow"
        android:layout_width="match_parent"
        android:layout_height="300dp"
        android:background="@drawable/bg_ambient_glow"
        android:alpha="0.4" />

    <!-- App Bar Toolbar -->
    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appBarLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@android:color/transparent"
        app:elevation="0dp">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:title="Identity Verification"
            app:titleTextColor="#FAFAFA"
            app:navigationIcon="@drawable/ic_arrow_left"
            app:navigationIconTint="#FAFAFA" />

    </com.google.android.material.appbar.AppBarLayout>

    <!-- Scrollable Main Content -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/nestedScrollView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingBottom="88dp"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingTop="12dp">

            <!-- Subtitle -->
            <TextView
                android:id="@+id/tvHeaderSubtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:text="Complete government identity verification to start receiving passenger bookings."
                android:textColor="#A1A1AA"
                android:textSize="14sp" />

            <!-- Skeleton Loading Shimmer -->
            <com.navassist.android.presentation.assistant.kyc.widgets.KycSkeletonView
                android:id="@+id/skeletonView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:visibility="gone" />

            <!-- Status Banner Card -->
            <com.navassist.android.presentation.assistant.kyc.widgets.KycStatusCard
                android:id="@+id/statusCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp" />

            <!-- Rejection Reason Card (Shown if Rejected) -->
            <com.navassist.android.presentation.assistant.kyc.widgets.RejectedReasonCard
                android:id="@+id/rejectedReasonCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:visibility="gone" />

            <!-- Success Animation Card (Shown if Verified) -->
            <com.navassist.android.presentation.assistant.kyc.widgets.SuccessAnimationView
                android:id="@+id/successView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:visibility="gone" />

            <!-- Verification Progress Timeline -->
            <com.navassist.android.presentation.assistant.kyc.widgets.VerificationTimelineView
                android:id="@+id/timelineView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp" />

            <!-- Document Upload Form Section -->
            <LinearLayout
                android:id="@+id/layoutUploadForm"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="REQUIRED IDENTITY DOCUMENTS"
                    android:textColor="#FAFAFA"
                    android:textSize="13sp"
                    android:fontFamily="sans-serif-medium"
                    android:textStyle="bold"
                    android:letterSpacing="0.05"
                    android:layout_marginBottom="12dp" />

                <!-- Aadhaar Input Field -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="14dp"
                    app:cardBackgroundColor="#18181B"
                    app:cardCornerRadius="18dp"
                    app:cardElevation="0dp"
                    app:strokeColor="#27272A"
                    app:strokeWidth="1.5dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="12-Digit Aadhaar Number *"
                            android:textColor="#A1A1AA"
                            android:textSize="12sp"
                            android:textStyle="bold" />

                        <EditText
                            android:id="@+id/etAadhaarNumber"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:background="@android:color/transparent"
                            android:hint="Enter 12-digit Aadhaar Number"
                            android:inputType="number"
                            android:maxLength="12"
                            android:textColor="#FAFAFA"
                            android:textColorHint="#71717A"
                            android:textSize="16sp" />

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <!-- Document Upload Card: Aadhaar Front -->
                <com.navassist.android.presentation.assistant.kyc.widgets.DocumentUploadCard
                    android:id="@+id/cardAadhaarFront"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="14dp" />

                <!-- Document Upload Card: Aadhaar Back -->
                <com.navassist.android.presentation.assistant.kyc.widgets.DocumentUploadCard
                    android:id="@+id/cardAadhaarBack"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="20dp" />

                <!-- Guidelines Checklist -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="PHOTO UPLOAD GUIDELINES"
                    android:textColor="#FAFAFA"
                    android:textSize="13sp"
                    android:fontFamily="sans-serif-medium"
                    android:textStyle="bold"
                    android:letterSpacing="0.05"
                    android:layout_marginBottom="12dp" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvChecklist"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false"
                    android:layout_marginBottom="20dp" />

                <!-- Security Encryption Card -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="24dp"
                    app:cardBackgroundColor="#111113"
                    app:cardCornerRadius="18dp"
                    app:cardElevation="0dp"
                    app:strokeColor="#27272A"
                    app:strokeWidth="1.5dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:padding="16dp"
                        android:gravity="center_vertical">

                        <ImageView
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:layout_marginEnd="12dp"
                            android:src="@drawable/ic_lock_outline"
                            app:tint="#22C55E" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Your documents are encrypted end-to-end and only accessed by authorized verification auditors."
                            android:textColor="#A1A1AA"
                            android:textSize="12sp" />

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

    <!-- Sticky Bottom Submit Button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnSubmitKyc"
        android:layout_width="match_parent"
        android:layout_height="54dp"
        android:layout_gravity="bottom"
        android:layout_margin="16dp"
        android:text="Submit Verification Documents"
        android:textColor="#09090B"
        android:textSize="16sp"
        android:textStyle="bold"
        app:backgroundTint="#FAFAFA"
        app:cornerRadius="16dp" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
