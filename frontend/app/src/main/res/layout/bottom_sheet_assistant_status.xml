<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="#18181B"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Working Status"
        android:textColor="#FAFAFA"
        android:textSize="20sp"
        android:fontFamily="sans-serif-medium"
        android:textStyle="bold" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:layout_marginBottom="20dp"
        android:text="Select your current availability status."
        android:textColor="#A1A1AA"
        android:textSize="13sp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnStatusOnline"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:layout_marginBottom="12dp"
        android:backgroundTint="#22C55E"
        android:text="Online &amp; Accepting Bookings 🟢"
        android:textColor="#09090B"
        android:textSize="14sp"
        android:textStyle="bold"
        app:cornerRadius="14dp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnStatusOffline"
        style="@style/Widget.Material3.Button.OutlinedButton"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:text="Go Offline 🔴"
        android:textColor="#FAFAFA"
        android:textSize="14sp"
        app:cornerRadius="14dp"
        app:strokeColor="#27272A" />

</LinearLayout>
