<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/pickupLocationContainer"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#09090B">

    <!-- Layer 0: Fullscreen MapLibre GL Vector Map -->
    <org.maplibre.android.maps.MapView
        android:id="@+id/mapView"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- Main Floating Overlays Container -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/overlayContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <!-- ═══════════════════════════════════════════════════════════ -->
        <!-- Layer 1: Top Section — Stepper & Search Bar                -->
        <!-- ═══════════════════════════════════════════════════════════ -->
        <LinearLayout
            android:id="@+id/layoutTopSection"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingTop="12dp"
            android:paddingEnd="16dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <!-- Stepper View (Step 1 of 7) -->
            <com.navassist.android.presentation.customviews.BookingStepperView
                android:id="@+id/stepperView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />

            <!-- Floating Material 3 Search Bar Container -->
            <com.navassist.android.presentation.widgets.search.SearchLocationView
                android:id="@+id/searchLocationView"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="10dp"
                android:elevation="14dp" />

        </LinearLayout>

        <!-- ═══════════════════════════════════════════════════════════ -->
        <!-- Layer 2: Center Interactive Animated Pickup Marker Pin     -->
        <!-- ═══════════════════════════════════════════════════════════ -->
        <LinearLayout
            android:id="@+id/layoutCenterPin"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:translationY="-24dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <!-- Pickup Location Badge -->
            <TextView
                android:id="@+id/tvPickupBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp"
                android:background="@drawable/bg_pickup_badge"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.05"
                android:text="PICKUP LOCATION"
                android:textColor="#22C55E"
                android:textSize="10sp"
                android:textStyle="bold" />

            <!-- Marker Icon Container -->
            <FrameLayout
                android:id="@+id/vPinContainer"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="@drawable/bg_glass_circle"
                android:elevation="12dp">

                <ImageView
                    android:id="@+id/ivCenterPin"
                    android:layout_width="26dp"
                    android:layout_height="26dp"
                    android:layout_gravity="center"
                    android:contentDescription="Set Pickup Location"
                    android:src="@drawable/ic_ms_location_on"
                    app:tint="#22C55E" />

            </FrameLayout>

            <!-- Soft Drop Shadow Base -->
            <View
                android:layout_width="16dp"
                android:layout_height="6dp"
                android:layout_marginTop="2dp"
                android:alpha="0.5"
                android:background="@drawable/bg_bottom_sheet_handle" />

        </LinearLayout>

        <!-- ═══════════════════════════════════════════════════════════ -->
        <!-- Layer 3: Right-Side Floating Map Control Stack (48dp)     -->
        <!-- ═══════════════════════════════════════════════════════════ -->
        <LinearLayout
            android:id="@+id/panelMapControls"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="16dp"
            android:layout_marginBottom="12dp"
            android:elevation="14dp"
            android:orientation="vertical"
            app:layout_constraintBottom_toTopOf="@id/layoutBottomSection"
            app:layout_constraintEnd_toEndOf="parent">

            <!-- Control 1: My Location -->
            <ImageView
                android:id="@+id/btnMyLocation"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_marginBottom="10dp"
                android:background="@drawable/bg_map_control_button"
                android:clickable="true"
                android:contentDescription="Center Location"
                android:focusable="true"
                android:padding="12dp"
                android:src="@drawable/ic_ms_my_location"
                app:tint="#FAFAFA" />

            <!-- Control 2: Map Layers -->
            <ImageView
                android:id="@+id/btnMapStyle"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_marginBottom="10dp"
                android:background="@drawable/bg_map_control_button"
                android:clickable="true"
                android:contentDescription="Map Style"
                android:focusable="true"
                android:padding="12dp"
                android:src="@drawable/ic_ms_layers"
                app:tint="#FAFAFA" />

            <!-- Control 3: Compass / Recenter -->
            <ImageView
                android:id="@+id/btnCompass"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="@drawable/bg_map_control_button"
                android:clickable="true"
                android:contentDescription="Compass"
                android:focusable="true"
                android:padding="12dp"
                android:src="@drawable/ic_ms_near_me"
                app:tint="#FAFAFA" />

        </LinearLayout>

        <!-- ═══════════════════════════════════════════════════════════ -->
        <!-- Layer 4: Bottom-Left "Use Current Location" Pill Button    -->
        <!-- ═══════════════════════════════════════════════════════════ -->
        <LinearLayout
            android:id="@+id/btnUseCurrentLocation"
            android:layout_width="wrap_content"
            android:layout_height="44dp"
            android:layout_marginStart="16dp"
            android:layout_marginBottom="12dp"
            android:background="@drawable/bg_current_location_pill"
            android:clickable="true"
            android:elevation="14dp"
            android:focusable="true"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="14dp"
            android:paddingEnd="16dp"
            app:layout_constraintBottom_toTopOf="@id/layoutBottomSection"
            app:layout_constraintStart_toStartOf="parent">

            <!-- Live Blue Location Dot -->
            <View
                android:layout_width="10dp"
                android:layout_height="10dp"
                android:layout_marginEnd="10dp"
                android:background="@drawable/bg_notification_badge"
                android:backgroundTint="#3B82F6" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-medium"
                android:text="Use Current Location"
                android:textColor="#FAFAFA"
                android:textSize="13sp" />

        </LinearLayout>

        <!-- ═══════════════════════════════════════════════════════════ -->
        <!-- Layer 5: Bottom Section — Location Details & Confirm CTA   -->
        <!-- ═══════════════════════════════════════════════════════════ -->
        <LinearLayout
            android:id="@+id/layoutBottomSection"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingBottom="16dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent">

            <!-- Selected Location Card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardPickupDetails"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="#161616"
                app:cardCornerRadius="20dp"
                app:cardElevation="12dp"
                app:strokeColor="#27272A"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="16dp">

                    <FrameLayout
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:background="@drawable/bg_glass_circle">

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:layout_gravity="center"
                            android:contentDescription="Pickup Point"
                            android:src="@drawable/ic_ms_location_on"
                            app:tint="#22C55E" />

                    </FrameLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:layout_marginEnd="8dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tvPickupTitle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:ellipsize="end"
                            android:fontFamily="sans-serif-medium"
                            android:maxLines="1"
                            android:textColor="#FAFAFA"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            tools:text="Kempegowda International Airport" />

                        <TextView
                            android:id="@+id/tvPickupSubtitle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:ellipsize="end"
                            android:fontFamily="sans-serif"
                            android:maxLines="1"
                            android:textColor="#A1A1AA"
                            android:textSize="12sp"
                            tools:text="Devanahalli, Bengaluru, Karnataka" />

                    </LinearLayout>

                    <ProgressBar
                        android:id="@+id/pbGeocodeLoading"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:indeterminateTint="#22C55E"
                        android:visibility="gone" />

                    <!-- Edit Icon Button -->
                    <ImageView
                        android:id="@+id/btnEditLocation"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:clickable="true"
                        android:contentDescription="Edit Location"
                        android:focusable="true"
                        android:padding="6dp"
                        android:src="@drawable/ic_ms_edit"
                        app:tint="#FAFAFA" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- 56dp Primary Confirm Pickup Button -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardContinueCta"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="12dp"
                android:clickable="true"
                android:contentDescription="Confirm Pickup Location"
                android:focusable="true"
                app:cardBackgroundColor="#FAFAFA"
                app:cardCornerRadius="28dp"
                app:cardElevation="14dp">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:paddingStart="20dp"
                    android:paddingEnd="10dp">

                    <TextView
                        android:id="@+id/tvContinueCta"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="sans-serif-medium"
                        android:letterSpacing="0.01"
                        android:text="Confirm Pickup Location"
                        android:textColor="#09090B"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <!-- Trailing Arrow inside Circular Black Container -->
                    <FrameLayout
                        android:id="@+id/vArrowCircle"
                        android:layout_width="38dp"
                        android:layout_height="38dp"
                        android:background="@drawable/bg_confirm_arrow_circle"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent">

                        <ImageView
                            android:id="@+id/ivArrow"
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:layout_gravity="center"
                            android:contentDescription="Next Step"
                            android:src="@drawable/ic_arrow_right"
                            app:tint="#FFFFFF" />

                    </FrameLayout>

                </androidx.constraintlayout.widget.ConstraintLayout>

            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>

        <!-- ═══════════════════════════════════════════════════════════ -->
        <!-- Layer 6: Elevated Top-Most Search Suggestions Dropdown      -->
        <!-- ═══════════════════════════════════════════════════════════ -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardSearchResults"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginTop="8dp"
            android:layout_marginEnd="16dp"
            android:elevation="32dp"
            android:translationZ="32dp"
            android:visibility="gone"
            app:cardBackgroundColor="#F7121214"
            app:cardCornerRadius="20dp"
            app:cardElevation="32dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/layoutTopSection"
            app:strokeColor="#27272A"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvSearchResults"
                    android:layout_width="match_parent"
                    android:layout_height="260dp"
                    android:paddingTop="4dp"
                    android:paddingBottom="4dp"
                    tools:listitem="@layout/item_location_search_result" />

                <!-- OpenStreetMap Attribution Text -->
                <TextView
                    android:id="@+id/tvOsmAttribution"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:paddingTop="6dp"
                    android:paddingBottom="10dp"
                    android:text="Powered by OpenStreetMap"
                    android:textColor="#52525B"
                    android:textSize="10sp"
                    android:fontFamily="sans-serif-medium" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
