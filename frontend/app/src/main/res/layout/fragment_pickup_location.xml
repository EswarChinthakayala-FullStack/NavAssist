<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/pickupLocationContainer"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#09090B">

    <!-- Layer 1: Fullscreen MapLibre GL Map -->
    <org.maplibre.android.maps.MapView
        android:id="@+id/mapView"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- Top Overlay: Booking Stepper & Floating Search Location View -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingTop="32dp"
        android:paddingEnd="20dp">

        <com.navassist.android.presentation.customviews.BookingStepperView
            android:id="@+id/stepperView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <com.navassist.android.presentation.widgets.search.SearchLocationView
            android:id="@+id/searchLocationView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:elevation="10dp" />

    </LinearLayout>

    <!-- Floating Map Pin in Center for Drag-to-Select -->
    <FrameLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center">

        <ImageView
            android:id="@+id/ivCenterPin"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:contentDescription="Set Pickup Location"
            android:src="@drawable/ic_benefit_nearby" />

    </FrameLayout>

    <!-- Bottom Floating Map Controls -->
    <com.navassist.android.presentation.widgets.controls.MapFloatingControls
        android:id="@+id/mapControls"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_marginEnd="20dp"
        android:layout_marginBottom="160dp" />

    <!-- Bottom Floating Container: Current Location Card & Continue CTA Button -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingBottom="24dp">

        <com.navassist.android.presentation.widgets.card.CurrentLocationCard
            android:id="@+id/cardCurrentLocation"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <!-- Search Results List Container -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvSearchResults"
            android:layout_width="match_parent"
            android:layout_height="180dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_input_field"
            android:visibility="gone"
            tools:listitem="@layout/item_location_search_result" />

        <!-- 60dp Pure White Continue CTA Button -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardContinueCta"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_marginTop="16dp"
            android:clickable="true"
            android:focusable="true"
            android:contentDescription="Continue"
            app:cardBackgroundColor="#FFFFFF"
            app:cardCornerRadius="20dp"
            app:cardElevation="8dp">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:paddingStart="24dp"
                android:paddingEnd="12dp">

                <TextView
                    android:id="@+id/tvContinueCta"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:letterSpacing="0.02"
                    android:text="Confirm Pickup Location"
                    android:textColor="#09090B"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <!-- Trailing Arrow inside Circular Black Container -->
                <FrameLayout
                    android:id="@+id/vArrowCircle"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="@drawable/bg_icon_circle"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent">

                    <ImageView
                        android:id="@+id/ivArrow"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_gravity="center"
                        android:contentDescription="Confirm Pickup Location"
                        android:src="@drawable/ic_arrow_right"
                        app:tint="#FFFFFF" />

                </FrameLayout>

            </androidx.constraintlayout.widget.ConstraintLayout>

        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
