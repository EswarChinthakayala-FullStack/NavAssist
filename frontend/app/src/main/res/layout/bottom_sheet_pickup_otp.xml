<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="#18181B"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Pickup Verification PIN"
        android:textColor="#FAFAFA"
        android:textSize="20sp"
        android:fontFamily="sans-serif-medium"
        android:textStyle="bold" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:layout_marginBottom="24dp"
        android:text="Share this 4-digit PIN with your guide to start the journey."
        android:textColor="#A1A1AA"
        android:textSize="13sp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="24dp"
        android:text="4 9 2 0"
        android:textColor="#22C55E"
        android:textSize="36sp"
        android:letterSpacing="0.3"
        android:fontFamily="sans-serif-medium"
        android:textStyle="bold" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnCloseOtp"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:backgroundTint="#FAFAFA"
        android:text="Done"
        android:textColor="#09090B"
        android:textSize="15sp"
        android:textStyle="bold"
        app:cornerRadius="14dp" />

</LinearLayout>
