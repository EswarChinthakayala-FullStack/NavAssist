<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="#18181B"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="NavAssist Wallet Balance"
        android:textColor="#FAFAFA"
        android:textSize="20sp"
        android:fontFamily="sans-serif-medium"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tvSheetBalance"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="₹500.00"
        android:textColor="#22C55E"
        android:textSize="28sp"
        android:fontFamily="sans-serif-medium"
        android:textStyle="bold" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:layout_marginBottom="24dp"
        android:text="Cashback &amp; Refunds included."
        android:textColor="#A1A1AA"
        android:textSize="13sp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnTopUpNow"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:backgroundTint="#FAFAFA"
        android:text="Top Up Funds"
        android:textColor="#09090B"
        android:textSize="15sp"
        android:textStyle="bold"
        app:cornerRadius="14dp" />

</LinearLayout>
