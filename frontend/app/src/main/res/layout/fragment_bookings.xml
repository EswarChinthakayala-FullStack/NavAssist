<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/bookingsCoordinator"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A0A0A">

    <!-- Ambient Glow Top Backdrop -->
    <View
        android:id="@+id/vAmbientGlow"
        android:layout_width="match_parent"
        android:layout_height="280dp"
        android:alpha="0.3"
        android:background="@drawable/bg_ambient_glow" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- Main Content Area with SwipeRefreshLayout -->
        <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
            android:id="@+id/swipeRefreshLayout"
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <androidx.core.widget.NestedScrollView
                android:id="@+id/nestedScrollView"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:clipToPadding="false"
                android:paddingBottom="24dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- ══════════════════════════════════════════════════════ -->
                    <!-- Booking Statistics Summary Header                     -->
                    <!-- ══════════════════════════════════════════════════════ -->
                    <HorizontalScrollView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:clipToPadding="false"
                        android:overScrollMode="never"
                        android:paddingStart="20dp"
                        android:paddingTop="4dp"
                        android:paddingEnd="20dp"
                        android:paddingBottom="12dp"
                        android:scrollbars="none">

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">

                            <!-- Stat 1: Total Trips -->
                            <LinearLayout
                                android:layout_width="120dp"
                                android:layout_height="80dp"
                                android:layout_marginEnd="12dp"
                                android:background="@drawable/bg_stat_card"
                                android:gravity="center_vertical"
                                android:orientation="vertical"
                                android:paddingStart="16dp"
                                android:paddingEnd="16dp">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:fontFamily="sans-serif"
                                    android:letterSpacing="0.04"
                                    android:text="TOTAL TRIPS"
                                    android:textColor="#71717A"
                                    android:textSize="10sp" />

                                <TextView
                                    android:id="@+id/tvStatTotalTrips"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="4dp"
                                    android:fontFamily="sans-serif-medium"
                                    android:text="15"
                                    android:textColor="#FAFAFA"
                                    android:textSize="22sp"
                                    android:textStyle="bold" />

                            </LinearLayout>

                            <!-- Stat 2: Completed -->
                            <LinearLayout
                                android:layout_width="120dp"
                                android:layout_height="80dp"
                                android:layout_marginEnd="12dp"
                                android:background="@drawable/bg_stat_card"
                                android:gravity="center_vertical"
                                android:orientation="vertical"
                                android:paddingStart="16dp"
                                android:paddingEnd="16dp">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:fontFamily="sans-serif"
                                    android:letterSpacing="0.04"
                                    android:text="COMPLETED"
                                    android:textColor="#22C55E"
                                    android:textSize="10sp" />

                                <TextView
                                    android:id="@+id/tvStatCompleted"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="4dp"
                                    android:fontFamily="sans-serif-medium"
                                    android:text="10"
                                    android:textColor="#FAFAFA"
                                    android:textSize="22sp"
                                    android:textStyle="bold" />

                            </LinearLayout>

                            <!-- Stat 3: Pending / Active -->
                            <LinearLayout
                                android:layout_width="120dp"
                                android:layout_height="80dp"
                                android:layout_marginEnd="12dp"
                                android:background="@drawable/bg_stat_card"
                                android:gravity="center_vertical"
                                android:orientation="vertical"
                                android:paddingStart="16dp"
                                android:paddingEnd="16dp">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:fontFamily="sans-serif"
                                    android:letterSpacing="0.04"
                                    android:text="PENDING"
                                    android:textColor="#F59E0B"
                                    android:textSize="10sp" />

                                <TextView
                                    android:id="@+id/tvStatPending"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="4dp"
                                    android:fontFamily="sans-serif-medium"
                                    android:text="2"
                                    android:textColor="#FAFAFA"
                                    android:textSize="22sp"
                                    android:textStyle="bold" />

                            </LinearLayout>

                            <!-- Stat 4: Amount Spent -->
                            <LinearLayout
                                android:layout_width="140dp"
                                android:layout_height="80dp"
                                android:background="@drawable/bg_stat_card"
                                android:gravity="center_vertical"
                                android:orientation="vertical"
                                android:paddingStart="16dp"
                                android:paddingEnd="16dp">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:fontFamily="sans-serif"
                                    android:letterSpacing="0.04"
                                    android:text="SPENT"
                                    android:textColor="#71717A"
                                    android:textSize="10sp" />

                                <TextView
                                    android:id="@+id/tvStatTotalSpent"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="4dp"
                                    android:fontFamily="sans-serif-medium"
                                    android:text="₹18,540"
                                    android:textColor="#FAFAFA"
                                    android:textSize="18sp"
                                    android:textStyle="bold" />

                            </LinearLayout>

                        </LinearLayout>

                    </HorizontalScrollView>

                    <!-- ══════════════════════════════════════════════════════ -->
                    <!-- Search Bar Card (56dp height, 28dp radius)            -->
                    <!-- ══════════════════════════════════════════════════════ -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/searchCard"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:layout_marginStart="20dp"
                        android:layout_marginTop="4dp"
                        android:layout_marginEnd="20dp"
                        android:layout_marginBottom="12dp"
                        app:cardBackgroundColor="#18181B"
                        app:cardCornerRadius="28dp"
                        app:cardElevation="0dp"
                        app:strokeColor="#27272A"
                        app:strokeWidth="1dp">

                        <androidx.constraintlayout.widget.ConstraintLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:paddingStart="16dp"
                            android:paddingEnd="16dp">

                            <ImageView
                                android:id="@+id/ivSearchLens"
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:contentDescription="Search"
                                android:src="@drawable/ic_ms_search"
                                app:layout_constraintBottom_toBottomOf="parent"
                                app:layout_constraintStart_toStartOf="parent"
                                app:layout_constraintTop_toTopOf="parent"
                                app:tint="#A1A1AA" />

                            <EditText
                                android:id="@+id/etSearch"
                                android:layout_width="0dp"
                                android:layout_height="match_parent"
                                android:layout_marginStart="12dp"
                                android:layout_marginEnd="12dp"
                                android:background="@android:color/transparent"
                                android:fontFamily="sans-serif-medium"
                                android:hint="Search booking by location or ID..."
                                android:imeOptions="actionSearch"
                                android:inputType="text"
                                android:textColor="#FAFAFA"
                                android:textColorHint="#71717A"
                                android:textSize="14sp"
                                app:layout_constraintEnd_toStartOf="@id/ivClearSearch"
                                app:layout_constraintStart_toEndOf="@id/ivSearchLens" />

                            <ImageView
                                android:id="@+id/ivClearSearch"
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:clickable="true"
                                android:contentDescription="Clear"
                                android:focusable="true"
                                android:src="@drawable/ic_close"
                                android:visibility="gone"
                                app:layout_constraintBottom_toBottomOf="parent"
                                app:layout_constraintEnd_toEndOf="parent"
                                app:layout_constraintTop_toTopOf="parent"
                                app:tint="#71717A" />

                        </androidx.constraintlayout.widget.ConstraintLayout>

                    </com.google.android.material.card.MaterialCardView>

                    <!-- ══════════════════════════════════════════════════════ -->
                    <!-- Filter Chips Bar                                      -->
                    <!-- ══════════════════════════════════════════════════════ -->
                    <com.google.android.material.chip.ChipGroup
                        android:id="@+id/chipGroupFilter"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="8dp"
                        android:paddingStart="20dp"
                        android:paddingEnd="20dp"
                        app:singleSelection="true">

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chipAll"
                            style="@style/Widget.Material3.Chip.Filter"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:checked="true"
                            android:text="All"
                            android:textColor="#FAFAFA"
                            app:chipBackgroundColor="#18181B"
                            app:chipStrokeColor="#27272A" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chipCompleted"
                            style="@style/Widget.Material3.Chip.Filter"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Completed"
                            android:textColor="#FAFAFA"
                            app:chipBackgroundColor="#18181B"
                            app:chipStrokeColor="#27272A" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chipPending"
                            style="@style/Widget.Material3.Chip.Filter"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Pending"
                            android:textColor="#FAFAFA"
                            app:chipBackgroundColor="#18181B"
                            app:chipStrokeColor="#27272A" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chipCancelled"
                            style="@style/Widget.Material3.Chip.Filter"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Cancelled"
                            android:textColor="#FAFAFA"
                            app:chipBackgroundColor="#18181B"
                            app:chipStrokeColor="#27272A" />

                    </com.google.android.material.chip.ChipGroup>

                    <!-- ══════════════════════════════════════════════════════ -->
                    <!-- Skeletons / Loading State Indicator                   -->
                    <!-- ══════════════════════════════════════════════════════ -->
                    <ProgressBar
                        android:id="@+id/progressBar"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center_horizontal"
                        android:layout_marginTop="32dp"
                        android:layout_marginBottom="32dp"
                        android:indeterminateTint="#FAFAFA"
                        android:visibility="gone" />

                    <!-- ══════════════════════════════════════════════════════ -->
                    <!-- Bookings List RecyclerView                            -->
                    <!-- ══════════════════════════════════════════════════════ -->
                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rvBookings"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:nestedScrollingEnabled="false"
                        tools:listitem="@layout/item_booking" />

                    <!-- ══════════════════════════════════════════════════════ -->
                    <!-- Empty State View Container                            -->
                    <!-- ══════════════════════════════════════════════════════ -->
                    <LinearLayout
                        android:id="@+id/layoutEmptyState"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:padding="40dp"
                        android:visibility="gone">

                        <ImageView
                            android:layout_width="64dp"
                            android:layout_height="64dp"
                            android:contentDescription="No Bookings"
                            android:src="@drawable/ic_ms_confirmation_number"
                            app:tint="#3F3F46" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="16dp"
                            android:fontFamily="sans-serif-medium"
                            android:text="No bookings yet"
                            android:textColor="#FAFAFA"
                            android:textSize="18sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:gravity="center"
                            android:text="Book your first assistant journey and track every step live."
                            android:textColor="#A1A1AA"
                            android:textSize="14sp" />

                        <!-- Book Assistant Action Button -->
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnBookFirstAssistant"
                            android:layout_width="wrap_content"
                            android:layout_height="52dp"
                            android:layout_marginTop="20dp"
                            android:backgroundTint="#FAFAFA"
                            android:fontFamily="sans-serif-medium"
                            android:paddingStart="24dp"
                            android:paddingEnd="24dp"
                            android:text="Book Assistant"
                            android:textColor="#09090B"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            app:cornerRadius="26dp" />

                    </LinearLayout>

                </LinearLayout>

            </androidx.core.widget.NestedScrollView>

        </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
