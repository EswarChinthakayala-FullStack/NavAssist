        tools:layout="@layout/fragment_bookings_management">
        <action
            android:id="@+id/action_admin_bookings_to_detail"
            app:destination="@id/adminBookingDetailFragment" />
    </fragment>

    <!-- Admin Booking Detail Destination -->
    <fragment
        android:id="@+id/adminBookingDetailFragment"
        android:name="com.navassist.android.presentation.admin.bookings.AdminBookingDetailFragment"
        android:label="Booking Audit Detail"
        tools:layout="@layout/fragment_admin_booking_detail">
        <argument
            android:name="bookingId"
            android:defaultValue="1"
            app:argType="integer" />
    </fragment>

    <!-- Admin User Management Destination -->
    <fragment
        android:id="@+id/userManagementFragment"
        android:name="com.navassist.android.presentation.admin.users.UserManagementFragment"
        android:label="User Management"
        tools:layout="@layout/fragment_user_management">
        <action
            android:id="@+id/action_admin_users_to_detail"
            app:destination="@id/userDetailFragment" />
    </fragment>

    <!-- Admin User Detail Destination -->
    <fragment
        android:id="@+id/userDetailFragment"
        android:name="com.navassist.android.presentation.admin.users.UserDetailFragment"
        android:label="User Profile Audit"
        tools:layout="@layout/fragment_user_detail">
        <argument
            android:name="userId"
            android:defaultValue="1"
            app:argType="integer" />
    </fragment>

    <!-- Admin Live SOS Alerts Destination -->
    <fragment
        android:id="@+id/sosAlertsFragment"
        android:name="com.navassist.android.presentation.admin.sos.SosAlertsFragment"
        android:label="Live SOS Emergency Monitor"
        tools:layout="@layout/fragment_sos_alerts" />

    <!-- Additional Guest Destinations -->
    <fragment
