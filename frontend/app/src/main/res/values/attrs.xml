<?xml version="1.0" encoding="utf-8"?>
<resources>
    <declare-styleable name="StatusBadgeView">
        <attr name="badgeStatus" format="enum">
            <enum name="pending" value="0" />
            <enum name="accepted" value="1" />
            <enum name="ongoing" value="2" />
            <enum name="completed" value="3" />
            <enum name="cancelled" value="4" />
        </attr>
    </declare-styleable>

    <declare-styleable name="RatingStarsView">
        <attr name="rating" format="float" />
        <attr name="starSize" format="dimension" />
        <attr name="isInteractive" format="boolean" />
    </declare-styleable>
</resources>
