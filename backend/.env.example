# FastAPI Core Settings
PROJECT_NAME="NavAssist API"
SECRET_KEY="replace-with-a-very-secure-random-secret-key-for-jwt"
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# MySQL Database Settings
MYSQL_SERVER="localhost"
MYSQL_PORT=3306
MYSQL_USER="root"
MYSQL_PASSWORD=""
MYSQL_DB="navassist"

# Redis Cache Settings
REDIS_HOST="localhost"
REDIS_PORT=6379
REDIS_DB=0

# Third-Party Integrations
# SMS (Twilio)
TWILIO_ACCOUNT_SID="your_twilio_account_sid"
TWILIO_AUTH_TOKEN="your_twilio_auth_token"
TWILIO_FROM_NUMBER="your_twilio_from_number"

# Push Notifications (FCM Disabled - Console print stubs active)

# Maps, Geocoding & Routing (OSRM, Nominatim & Photon - Purely free & open-source, no API keys required)
# GOOGLE_MAPS_API_KEY is no longer required.

# Payments (Razorpay)
RAZORPAY_KEY_ID="rzp_test_yourKeyId"
RAZORPAY_KEY_SECRET="yourRazorpayKeySecret"
RAZORPAY_WEBHOOK_SECRET="yourRazorpayWebhookSecret"

# File Storage Configuration (AWS S3 Disabled - Running purely locally in backend/uploads)
STORAGE_TYPE="local"
UPLOADS_DIR="uploads"
